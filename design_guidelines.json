{
  "brand_identity": {
    "name": "Itihaasa Foods",
    "sub_brands": ["Fresh Bean", "Bean & Brew"],
    "personality": "Warm, Elegant, Boutique, Premium, Inviting",
    "tone": "Sophisticated, Comforting, Welcoming",
    "target_audience": "Cafe customers scanning QR codes, mobile users",
    "context": "Digital Menu & Marketing Site"
  },
  "visual_design": {
    "theme_mode": "light",
    "colors": {
      "primary": {
        "espresso": "#3E2723",
        "ivory_beige": "#FFF8E1",
        "coffee_cream": "#D7CCC8"
      },
      "secondary": {
        "warm_copper": "#BCAAA4",
        "soft_cream": "#FFF3E0"
      },
      "text": {
        "primary": "#212121",
        "secondary": "#5D4037",
        "inverted": "#FFFFFF"
      },
      "background": {
        "main": "#FFF8E1",
        "card": "#FFFFFF",
        "accent": "#F5EFE6"
      },
      "status": {
        "success": "#558B2F",
        "error": "#C62828",
        "warning": "#EF6C00"
      }
    },
    "typography": {
      "headings": {
        "family": "\"Playfair Display\", serif",
        "weights": ["400", "700"],
        "usage": "All section titles, hero text, product names"
      },
      "body": {
        "family": "\"Lato\", sans-serif",
        "weights": ["400", "700"],
        "usage": "Descriptions, prices, navigation, buttons"
      }
    },
    "spacing": {
      "scale": "tailwind",
      "base_padding": "p-6",
      "section_gap": "gap-12",
      "container_padding": "px-4 md:px-8 lg:px-16"
    },
    "effects": {
      "shadows": {
        "card": "0 4px 20px -2px rgba(62, 39, 35, 0.1)",
        "hover": "0 10px 25px -5px rgba(62, 39, 35, 0.15)",
        "floating": "0 20px 40px -5px rgba(62, 39, 35, 0.2)"
      },
      "radius": {
        "card": "rounded-xl",
        "button": "rounded-full"
      }
    }
  },
  "layout_strategy": {
    "type": "mobile_first",
    "grid_system": {
      "mobile": "grid-cols-1",
      "tablet": "grid-cols-2",
      "desktop": "grid-cols-3 lg:grid-cols-4"
    },
    "navigation": {
      "style": "sticky_pill_bar",
      "location": "top_below_hero"
    }
  },
  "components": {
    "hero": {
      "type": "immersive_image",
      "overlay": "gradient-to-t from-[#3E2723]/80 to-transparent",
      "content_alignment": "center"
    },
    "menu_card": {
      "style": "minimalist_elegant",
      "layout": "image_top_or_left",
      "price_style": "bold_espresso",
      "interaction": "modal_popup_on_click"
    },
    "buttons": {
      "primary": "bg-[#3E2723] text-[#FFF8E1] hover:bg-[#5D4037] transition-all duration-300",
      "secondary": "border-2 border-[#3E2723] text-[#3E2723] hover:bg-[#3E2723] hover:text-[#FFF8E1] transition-all duration-300",
      "floating_action": "fixed bottom-6 right-6 z-50 shadow-xl"
    }
  },
