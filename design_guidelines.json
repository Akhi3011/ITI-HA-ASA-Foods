    "icons": {
      "library": "lucide-react",
      "style": "stroke-1"
    }
  },
  "instructions_to_main_agent": [
    "Install 'framer-motion' for smooth entrance animations.",
    "Use 'Playfair Display' from Google Fonts via simple import in index.css.",
    "Ensure the layout is perfectly responsive on mobile (375px width).",
    "Implement a 'Sticky Category Nav' that slides horizontally on mobile.",
    "The 'Menu' page should be the main focus after the hero section.",
    "Use the provided colors strictly - do not use default black/white.",
    "For the 'About Us' section, place it at the bottom with the interior image.",
    "Create a 'DigitalMenu' component that filters items by category.",
    "Use 'sonner' for any toast notifications (e.g., 'Added to cart' - simulation only).",
    "Ensure high contrast between text and background as per accessibility rules.",
    "Add 'data-testid' to all interactive elements."
  ],
  "universal_guidelines": [
    "Avoid generic centered layouts; use asymmetry where possible.",
    "Micro-animations on hover/tap are mandatory.",
    "Use generous padding (py-16, py-24) to create a premium feel.",
    "No gradients on text.",
    "Images should have a subtle warm overlay if they are too cool/blue."
  ]
}